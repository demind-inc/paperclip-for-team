

PORT=3100
SERVE_UI=true

# Authenticated mode + Supabase Auth
PAPERCLIP_DEPLOYMENT_MODE=authenticated
# For RS256/JWKS verification (recommended for newer Supabase projects). Same as VITE_SUPABASE_URL.
SUPABASE_URL=https://your-project-ref.supabase.co
# Optional: for legacy HS256 verification (Project Settings > API > JWT Secret)
# SUPABASE_JWT_SECRET=

# Optional: when using Better Auth instead of Supabase
# BETTER_AUTH_SECRET=
